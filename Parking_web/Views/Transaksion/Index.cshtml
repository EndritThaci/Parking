@model IEnumerable<Parking_web.Models.DTO.TransaksionRead>

<div class="container-fluid px-0">
    @{
        var totaliGjithsej = Model?.Where(t => t.Cmimi.HasValue).Sum(t => t.Cmimi!.Value) ?? 0;

        var totaliMuaji = Model?.Where(t => t.Cmimi.HasValue &&
        t.KohaHyrjes.Month == DateTime.Now.Month &&
        t.KohaHyrjes.Year == DateTime.Now.Year)
        .Sum(t => t.Cmimi!.Value) ?? 0;

        var totaliViti = Model?.Where(t => t.Cmimi.HasValue &&
        t.KohaHyrjes.Year == DateTime.Now.Year)
        .Sum(t => t.Cmimi!.Value) ?? 0;

        var njesite = Model?.Where(n => n != null).Select(t => new { t.Cilsimi.NjesiOrg.NjesiteId, t.Cilsimi.NjesiOrg.Emri }).Distinct().OrderBy(n => n.Emri).ToList();
    }

    

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-black text-white pt-4 px-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h4 class="fw-bold mb-0">Historia e Transaksioneve</h4>
                    <small class="opacity-75">Regjistri i hyrjeve dhe daljeve</small>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div class="action-button-area d-flex gap-2 me-3">
                        <a asp-controller="LibriShitjes" asp-action="GetLibriCustom" class="btn btn-outline-light px-4 rounded-pill fw-bold">Gjenero Librin e Shitjes</a>
                    </div>
                    <div style="min-width: 250px;">
                    
                        <div class="input-group shadow-sm">
                            <select id="filterNjesia" class="form-select bg-black fw-bold text-white rounded-pill">
                                <option value="">Të gjitha Njësitë</option>
                                @if (njesite != null)
                                {
                                    foreach (var njesi in njesite)
                                    {
                                        <option value="@njesi.NjesiteId">@njesi.Emri</option>
                                    }
                                }
                            }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 w-100" id="transaksionetTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Vend Parkimi</th>
                            <th>Perdoruesi</th>
                            <th>Hyrja</th>
                            <th>Dalja</th>
                            <th>Statusi</th>
                            <th>Shërbimet</th>
                            <th class="text-end pe-4">Pagesa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            foreach (var t in Model.OrderByDescending(x => x.KohaHyrjes))
                            {
                                <tr class="transaksion-row"
                                    style="cursor: pointer;"
                                    data-id="@t.TransaksioniId"
                                    data-njesi-id="@t.Cilsimi?.NjesiOrg?.NjesiteId"
                                    data-njesia="@t.Cilsimi?.NjesiOrg?.Emri"
                                    data-cmimi="@(t.Cmimi ?? 0)"
                                    data-muaji="@t.KohaHyrjes.Month"
                                    data-viti="@t.KohaHyrjes.Year">
                                    <td class="ps-4">
                                        <span class="fw-bold text-dark">@t.Vendi?.VendiEmri, @t.Cilsimi?.NjesiOrg?.Emri</span>
                                    </td>
                                    <td>@t.Useri?.Emri @t.Useri?.Mbiemri</td>
                                    <td>@t.KohaHyrjes.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(t.KohaDaljes.HasValue? t.KohaDaljes.Value.ToString("dd/MM/yyyy HH:mm") : "--:--")</td>
                                    <td>
                                        <span class="badge @(t.Statusi?.ToLower() == "completed" ? "bg-primary-subtle text-primary" : "bg-warning-subtle text-secondary") rounded-pill px-3">
                                            @t.Statusi
                                        </span>
                                    </td>
                                    <td>
                                        @if (t.Sherbimi != null)
                                        {
                                            foreach (var s in t.Sherbimi)
                                            {
                                                <span class="badge bg-light text-dark border fw-normal">@s.Emri</span>
                                            }
                                        }
                                    </td>
                                    @if (t.Cmimi.HasValue && t.Cmimi > 0)
                                    {
                                        <td class="text-end pe-4 fw-bold text-primary">
                                            @(t.Cmimi.Value.ToString("N2") + " €")
                                        </td>                    
                                    }
                                    else
                                    {
                                        <td class="text-end pe-4 text-dark">
                                            Në proces
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="row g-3 mb-4 mt-4">
        <div class="col-md-4">
            <div id="btnRaportMuaji" class="card border-0 shadow-sm bg-black text-white h-100 btn-hover-excel transition-up" style="cursor:pointer;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="text-uppercase small fw-bold opacity-75 mb-1">Totali Për këtë Muaj</h6>
                        <i class="bi bi-file-earmark-excel text-success"></i>
                    </div>
                    <h2 class="fw-bold mb-0"><span id="summaryMuaji">@totaliMuaji.ToString("N2")</span> €</h2>
                    <small class="text-white mt-2 d-block fw-bold"><i class="bi bi-download me-1"></i> Shkarko Raportin</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div id="btnRaportViti" class="card border-0 shadow-sm bg-black text-white h-100 btn-hover-excel transition-up" style="cursor:pointer;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="text-uppercase small fw-bold opacity-75 mb-1">Totali Për këtë Vit</h6>
                        <i class="bi bi-file-earmark-excel text-success"></i>
                    </div>
                    <h2 class="fw-bold mb-0"><span id="summaryViti">@totaliViti.ToString("N2")</span> €</h2>
                    <small class="text-white mt-2 d-block fw-bold"><i class="bi bi-download me-1"></i> Shkarko Raportin</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div id="btnRaportGjithsej" class="card border-0 shadow-sm bg-black text-white h-100 btn-hover-excel transition-up" style="cursor:pointer;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="text-uppercase small fw-bold opacity-75 mb-1">Total Gjithsej</h6>
                        <i class="bi bi-file-earmark-excel text-success"></i>
                    </div>
                    <h2 class="fw-bold mb-0"><span id="summaryGjithsej">@totaliGjithsej.ToString("N2")</span> €</h2>
                    <small class="text-white mt-2 d-block fw-bold"><i class="bi bi-download me-1"></i> Shkarko Raportin</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const urlParams = new URLSearchParams(window.location.search);
            const njesiaNgaUrl = urlParams.get('njesiaId');

            if (njesiaNgaUrl) {
                const filterSelect = document.getElementById('filterNjesia');

                filterSelect.value = njesiaNgaUrl;

                filterSelect.dispatchEvent(new Event('change'));
            }
        });

        document.getElementById('filterNjesia').addEventListener('change', function() {
            const selectedNjesiId  = this.value;
            const rows = document.querySelectorAll('.transaksion-row');
            const now = new Date();
            const currentMonth = now.getMonth() + 1;
            const currentYear = now.getFullYear();

            let totalGjithsej = 0;
            let totalMuaji = 0;
            let totalViti = 0;

            rows.forEach(row => {
                const rowNjesiaId = row.getAttribute('data-njesi-id');
                const cmimi = parseFloat(row.getAttribute('data-cmimi')) || 0;
                const rreshtMuaji = parseInt(row.getAttribute('data-muaji'));
                const rreshtViti = parseInt(row.getAttribute('data-viti'));

                if (selectedNjesiId === "" || rowNjesiaId === selectedNjesiId) {
                    row.style.display = "";

                    totalGjithsej += cmimi;
                    if (rreshtViti === currentYear) {
                        totalViti += cmimi;
                        if (rreshtMuaji === currentMonth) {
                            totalMuaji += cmimi;
                        }
                    }
                } else {
                    row.style.display = "none";
                }
            });

            document.getElementById('summaryGjithsej').innerText = totalGjithsej.toLocaleString('sq-AL', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            document.getElementById('summaryMuaji').innerText = totalMuaji.toLocaleString('sq-AL', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            document.getElementById('summaryViti').innerText = totalViti.toLocaleString('sq-AL', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        });

        function downloadReport(params) {
                const njesiaId = document.getElementById('filterNjesia').value;
                let url = "/LibriShitjes/GetLibri?";

                let queryParts = [];
                for (let key in params) {
                    queryParts.push(`${key}=${params[key]}`);
                }

                if (njesiaId) {
                    queryParts.push(`njesia=${encodeURIComponent(njesiaId)}`);
                }

                window.location.href = url + queryParts.join('&');
            }

        document.getElementById('btnRaportMuaji').addEventListener('click', function() {
            const now = new Date();
            downloadReport({ month: now.getMonth() + 1, year: now.getFullYear() });
        });

        document.getElementById('btnRaportViti').addEventListener('click', function() {
            downloadReport({ year: new Date().getFullYear() });
        });

        document.getElementById('btnRaportGjithsej').addEventListener('click', function() {
            downloadReport({ all: true });
        });

        document.querySelectorAll('.transaksion-row').forEach(row => {
            row.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                if(id) window.location.href = `/LibriShitjes/GetLibri?id=${id}`;
            });
        });
    </script>
    <style>
            .transition-up {
                transition: transform 0.2s ease-in-out;
                display: block;
            }

                .transition-up:hover {
                    transform: translateY(-5px);
                }

            .btn-hover-excel {
                border: 1px solid transparent !important;
                transition: all 0.3s ease;
            }

                .btn-hover-excel:hover {
                    background-color: #1a1a1a !important;
                }
    </style>
}