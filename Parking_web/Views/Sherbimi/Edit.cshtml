@model Parking_web.Models.DTO.SherbimiUpdateDTO
@{
    ViewData["Title"] = "Përditësimi i Shërbimit";
}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-white py-3">
                    <span class="fw-bold h4 mb-0">Përditëso Shërbimin</span>
                </div>

                <div class="card-body p-4">
                    <form method="post">

                        <input type="hidden" asp-for="SherbimiId" />

                        <div class="mb-3">
                            <label asp-for="Emri" class="form-label fw-semibold">Emri i Shërbimit</label>
                            <input asp-for="Emri" class="form-control" placeholder="Shëno emrin e shërbimit" />
                            <span asp-validation-for="Emri" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Cmimi" class="form-label fw-semibold">Çmimi (€)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">€</span>
                                <input asp-for="Cmimi"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       class="form-control"
                                       placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Cmimi" class="text-danger small"></span>
                            <div class="form-text text-muted small">Shëno 0.00 nëse shërbimi është pa pagesë.</div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end border-top pt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                                Kthehu
                            </a>
                            <button type="submit" class="btn btn-warning text-white px-4 rounded-pill fw-bold shadow-sm">
                                Ruaj Ndryshimet
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}