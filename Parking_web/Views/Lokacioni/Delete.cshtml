@model Parking_web.Models.Lokacioni
@{
    ViewData["Title"] = "Fshirja e Lokacionit";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-bottom-5">
                <div class="card-header bg-danger text-white py-3 text-center rounded-top-5">
                    <h5 class="mb-0 fw-bold">Konfirmo Fshirjen e Lokacionit</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-geo-alt-fill text-danger" style="font-size: 3rem;"></i>
                        <h4 class="mt-2 text-dark">A jeni i sigurt?</h4>
                        <p class="text-muted">Po fshini lokacionin në <strong>Katin @Model.Kati</strong> për njësinë me ID <strong>#@Model.NjesiteId</strong>.</p>
                    </div>

                    <div class="bg-light p-3 rounded mb-4 text-start">
                        <div class="small text-muted text-uppercase fw-bold mb-2">Detajet:</div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span>Kati:</span> <span class="fw-bold">@Model.Kati</span>
                        </div>
                        <div class="d-flex justify-content-between py-2">
                            <span>Lidhur me Njësinë:</span> <span class="fw-bold text-primary">ID #@Model.NjesiteId</span>
                        </div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="LokacioniId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">Po, Fshije</button>
                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">Anulo</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>