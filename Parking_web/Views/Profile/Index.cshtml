@model Parking_web.Models.Useri

@{
    ViewData["Title"] = "Profili";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4 mb-4">
                <div class="mb-3">
                    <img src="https://ui-avatars.com/api/?name=@Model.Emri+@Model.Mbiemri&background=0d6efd&color=fff&size=128"
                         class="rounded-circle shadow-sm border border-3 border-white" alt="Profile Picture">
                </div>
                <h4 class="fw-bold mb-0">@Model.Emri @Model.Mbiemri</h4>
                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 mt-2">
                    <i class="bi bi-shield-check me-1"></i> @Model.Role
                </span>

                <hr class="my-4 opacity-50">

                <div class="text-start">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-shape bg-light rounded-3 me-3">
                            <i class="bi bi-building text-muted"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">Biznesi / Organizata</small>
                            <span class="fw-semibold">@(Model.Organizata?.EmriBiznesit ?? "Pa Organizatë")</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center">
                        
                        @if (User.IsInRole("Manager"))
                        {
                            <div class="icon-shape bg-light rounded-3 me-3">
                                <i class="bi bi-geo-alt text-muted"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Njësia Organizative</small>
                                <span class="fw-semibold">@(Model.Njesi?.Emri ?? "Pa Njësi")</span>
                            </div>
                        }
                        
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h5 class="fw-bold mb-4">Të dhënat Personale</h5>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Emri</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model.Emri" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Mbiemri</label>
                        <input type="text" class="form-control bg-light border-0" value="@Model.Mbiemri" readonly>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted">Adresa Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-envelope"></i></span>
                            <input type="text" class="form-control bg-light border-0" value="@Model.Email" readonly>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <h5 class="fw-bold mb-3 text-primary small text-uppercase">Siguria</h5>

                    <div id="passwordBtnSection">
                        <button type="button" onclick="togglePasswordForm()" class="btn btn-outline-primary btn-sm rounded-pill px-4">
                            <i class="bi bi-key me-1"></i> Ndrysho Passwordin
                        </button>
                    </div>

                    <div id="passwordFormSection" style="display: none;">
                        <form asp-controller="Profile" asp-action="ChangePassword" method="post" class="bg-light p-3 rounded-4 shadow-sm">
                            @Html.AntiForgeryToken()
                            <div class="row g-2">
                                <div class="col-12">
                                    <input type="password" name="OldPassword" class="form-control form-control-sm border-0 shadow-sm" placeholder="Passwordi aktual" required>
                                </div>
                                <div class="col-md-12">
                                    <input type="password" name="NewPassword" class="form-control form-control-sm border-0 shadow-sm" placeholder="Passwordi i ri" required>
                                </div>
                                <div class="col-md-12">
                                    <input type="password" name="ConfirmPassword" class="form-control form-control-sm border-0 shadow-sm" placeholder="Konfirmo passwordin" required>
                                </div>
                                <div class="col-12 d-flex gap-2 mt-2">
                                    <button type="submit" class="btn btn-primary btn-sm rounded-pill flex-grow-1">
                                        Ruaj Ndryshimet
                                    </button>
                                    <button type="button" onclick="togglePasswordForm()" class="btn btn-light btn-sm rounded-pill border shadow-sm px-3">
                                        Kthehu
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h5 class="fw-bold mb-4">
                    <i class="bi bi-credit-card-2-front me-2 text-primary"></i>Llogaritë dhe Kartelat
                </h5>

                @{
                    var cards = ViewBag.CardDetails as IEnumerable<Parking_web.Models.CardDetails>;
                }

                @if (cards != null && cards.Any())
                {
                    <div class="row g-3 mb-4">
                        @foreach (var card in cards)
                        {
                            <div class="col-md-6">
                                <div class="p-3 ps-2 rounded-4 border bg-gradient position-relative overflow-hidden"
                                     style="min-height: 160px;">

                                    <div class="d-flex justify-content-between mb-3">
                                        <i class="bi bi-sim fs-3 text-primary"></i>
                                        <span class="fw-bold small text-uppercase opacity-75">@card.BankAccount.Bank.Name</span>
                                    </div>

                                    
                                    @if (card.CardNumber.Length == 16) 
                                    {
                                        <h5 class="mb-3 tracking-widest text-center"> 
                                            @card.CardNumber.Substring(0,4) 
                                            @card.CardNumber.Substring(4,4)
                                            @card.CardNumber.Substring(8,4)
                                            @card.CardNumber.Substring(12,4)
                                        </h5>
                                    }
                                    else
                                    {
                                        <h5 class="mb-3 tracking-widest text-center">
                                            @card.CardNumber
                                        </h5>
                                    }
                                    

                                    <div class="d-flex justify-content-between align-items-end mt-auto">
                                        <div>
                                            <small class="d-block opacity-50" style="font-size: 0.7rem;">PRONARI</small>
                                            <span class="small fw-semibold">@Model.Emri @Model.Mbiemri</span>
                                        </div>
                                        <div class="text-end">
                                            <small class="d-block opacity-50" style="font-size: 0.7rem;">SKADIMI</small>
                                            <span class="small fw-semibold">@card.ExpirationDate.ToString("MM/yy")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-light border-0 small rounded-3 mb-4 text-center py-3">
                        <i class="bi bi-wallet2 fs-2 d-block mb-2 text-muted"></i>
                        Nuk keni asnjë kartelë të regjistruar.
                    </div>
                }
            </div>
        
            <div>
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <h5 class="fw-bold mb-4">
                        <i class="bi bi-credit-card-2-front me-2 text-primary"></i>Lidhu me Kartelën Bankare
                    </h5>

                    <form asp-controller="BankAccount" asp-action="createAccount" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small text-muted fw-bold">Emri i Llogarisë</label>
                                <input type="text" name="AccountName" class="form-control bg-light border-0" placeholder="Psh. Llogaria rrjedhëse" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-muted fw-bold">Emri mbi Kartelë</label>
                                <input type="text" name="CardName" class="form-control bg-light border-0" placeholder="Psh. Filan Fisteku" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small text-muted fw-bold">Numri i Llogarisë (IBAN)</label>
                                <input type="text" name="AccountNumber" class="form-control bg-light border-0" placeholder="XK00..." required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-muted fw-bold">Numri i Kartelës</label>
                                <input type="text"
                                       id="cardVisualInput"
                                       class="form-control bg-light border-0"
                                       placeholder="0000 0000 0000 0000"
                                       required>

                                <input type="hidden" name="CardNumber" id="cardRealInput">

                                <div id="cardError" class="text-danger" style="font-size: 0.7rem; display: none;">
                                    Duhen saktësisht 16 shifra.
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label small text-muted fw-bold">Shuma e Parave</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0">€</span>
                                    <input type="number" step="0.01" name="Amount" class="form-control bg-light border-0" value="0.00" required>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label small text-muted fw-bold">Përzgjedh Bankën</label>
                                <select name="BankId" class="form-select bg-light border-0"
                                        asp-items="@(new SelectList(ViewBag.Banks, "Value", "Text"))" required>
                                    <option value="" selected disabled>-- Zgjedh Bankën --</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label small text-muted fw-bold">Data e Skadimit</label>
                                <input type="date" name="ExpirationDate" class="form-control bg-light border-0" required>
                            </div>

                            <div class="col-12 mt-4 text-end">
                                <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">
                                    <i class="bi bi-plus-circle me-2"></i>Krijo Llogarinë
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                @if(User.IsInRole("Manager") || User.IsInRole("Admin"))
                {
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-3">Veprime të Shpejta</h5>
                        <div class="d-flex gap-2">
                            <a asp-controller="Transaksion" asp-action=@(User.IsInRole("Manager")?"IndexManager":"Index") class="btn btn-light border flex-grow-1 rounded-3">
                                <i class="bi bi-list-ul d-block mb-1 fs-4"></i> Transaksionet
                            </a>
                            <a asp-controller="LibriShitjes" asp-action="GetLibriCustom" class="btn btn-light border flex-grow-1 rounded-3">
                                <i class="bi bi-file-earmark-excel d-block mb-1 fs-4"></i> Raportet
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .icon-shape {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .form-control[readonly] {
        cursor: default;
        font-weight: 500;
    }
    .tracking-widest {
        letter-spacing: 0.2rem;
    }
    .bg-gradient:hover {
        transform: translateY(-3px);
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }
</style>

<script>
    function togglePasswordForm() {
        const btnSection = document.getElementById('passwordBtnSection');
        const formSection = document.getElementById('passwordFormSection');

        if (formSection.style.display === 'none') {
            formSection.style.display = 'block';
            btnSection.style.display = 'none';
        } else {
            formSection.style.display = 'none';
            btnSection.style.display = 'block';
        }
    }

    document.getElementById('cardVisualInput').addEventListener('input', function (e) {
        let rawValue = e.target.value.replace(/\D/g, '');

        if (rawValue.length > 16) {
            rawValue = rawValue.slice(0, 16);
        }

        document.getElementById('cardRealInput').value = rawValue;

        let formatted = rawValue.match(/.{1,4}/g)?.join(' ') || rawValue;
        e.target.value = formatted;

        const errorDiv = document.getElementById('cardError');
        if (rawValue.length > 0 && rawValue.length < 16) {
            errorDiv.style.display = 'block';
        } else {
            errorDiv.style.display = 'none';
        }
    });
</script>