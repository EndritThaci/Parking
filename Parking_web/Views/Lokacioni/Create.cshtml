@model Parking_web.Models.Lokacioni

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold">Shto Lokacion të Ri</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Kati" class="form-label fw-semibold">Numri i Katit</label>
                            <input asp-for="Kati" type="number" class="form-control" placeholder="Psh: 1, 2, -1" />
                            <span asp-validation-for="Kati" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="NjesiteId" class="form-label fw-semibold">Përzgjidh Njësinë</label>

                            @if (ViewBag.IsFixed == true)
                            {
                                <select asp-for="NjesiteId" class="form-select bg-light text-muted"
                                        asp-items="ViewBag.NjesiteList" disabled>
                                </select>

                                <input type="hidden" asp-for="NjesiteId" />
                                <small class="text-info"><i class="bi bi-info-circle me-1"></i> Njësia është paracaktuar.</small>
                            }
                            else
                            {
                                <select asp-for="NjesiteId" class="form-select"
                                        asp-items="ViewBag.NjesiteList">
                                    <option value="" selected disabled>-- Zgjedh Njësinë --</option>
                                </select>
                            }
                            <span asp-validation-for="NjesiteId" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Anulo</a>
                            <button type="submit" class="btn btn-primary px-4 rounded-pill fw-bold">Ruaj Lokacionin</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>