@using Parking_web.Models.DTO
@model IEnumerable<NjesiReadDto>
@if (User.Identity == null || !User.Identity.IsAuthenticated)
{
    Context.Response.Redirect(Url.Action("Login", "Auth")!);
}
else if (User.IsInRole("Super Admin"))
{
    Context.Response.Redirect(Url.Action("Index", "Organizata")!);
}
else
{
    var pendingList = (ViewBag.PendingTransactions as List<TransaksionRead>)?.OrderBy(t => t.KohaHyrjes).ToList();

    ViewData["Title"] = "Shtepia";

<div class="container py-5">

        @if ((pendingList != null && pendingList.Any()))
        {
            var sum = pendingList.Count;
            <div class="mb-5">
                <div class="d-flex align-items-center mb-3 justify-content-center"
                     style="cursor: pointer;"
                     data-bs-toggle="collapse"
                     data-bs-target="#activeTransactions"
                     aria-expanded="true"
                     aria-controls="activeTransactions">

                    <div class="spinner-grow text-warning spinner-grow-sm me-2" role="status"></div>
                    <h5 class="fw-bold text-dark mb-0">Transaksionet tuaja aktive (@sum)</h5>
                    <i class="bi bi-chevron-down ms-2 transition-all collapse-arrow"></i>
                </div>

                <div class="collapse show" id="activeTransactions">
                    <div class="row g-3 justify-content-center pt-2">
                        <div class="row g-3 justify-content-center">

                            @foreach (var item in pendingList)
                            {
                                <div class="col-md-6 col-lg-4">
                                    <div class="card border-0 shadow-sm h-100 overflow-hidden position-relative pending-card">
                                        <div class="pending-stripe"></div>
                                        <div class="card-body p-4">
                                            <a asp-controller="Home" asp-action="Pay" asp-route-id="@item.TransaksioniId" class="text-decoration-none">
                                                <div class="d-flex justify-content-between align-items-start mb-3">
                                                    <div>
                                                        <h6 class="text-muted small text-uppercase fw-bold mb-1">Vendi i Parkimit</h6>
                                                        <h4 class="fw-black mb-0">@item.Njesia.Emri</h4>
                                                    </div>

                                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 rounded-pill">
                                                        Në proces
                                                    </span>
                                                </div>

                                                <div class="d-flex align-items-center text-muted small">
                                                    <i class="bi bi-clock-history me-2"></i>
                                                    <span>Hyrja: <strong>@item.KohaHyrjes.ToString("HH:mm")</strong></span>
                                                    <span class="mx-2">|</span>
                                                    <span>Data: @item.KohaHyrjes.ToString("dd/MM")</span>
                                                </div>
                                                <div class="d-flex align-items-center text-muted small mb-4">
                                                    <span><i class="bi bi-person-fill me-2"></i>Perdoruesi: @item.Useri.Emri @item.Useri.Mbiemri</span>
                                                </div>

                                                <a asp-controller="Home" asp-action="Pay" asp-route-id="@item.TransaksioniId"
                                                   class="btn btn-outline-warning w-100 rounded-pill fw-bold py-2 shadow-sm transition-all btn-pay">
                                                    Përzgjidh për Mbyllje
                                                </a>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <hr class="mt-5 mb-4 opacity-10">
            </div>
        }
    <div class="text-center mb-4 mt-5">
        
        <h3 class="fw-bold text-dark">Njësitë</h3>
        <p>Zgjedh Njësinë për të regjistruar nje transaksion</p>
    </div>

    <div class="row g-3 justify-content-center">
        @if (Model != null && Model.Any())
        {
            foreach (var njesi in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 overflow-hidden position-relative unit-card transition-all">
                        <div class="unit-stripe"></div>

                        <div class="card-body p-4">
                            <a asp-controller="Home" asp-action="Vendi" asp-route-njesiaId="@njesi.NjesiteId" class=" text-decoration-none">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h6 class="text-muted small text-uppercase fw-bold mb-1">Kodi: @njesi.Kodi</h6>
                                        <h4 class="fw-black mb-0 text-dark">@njesi.Emri</h4>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center text-muted small mb-4">
                                    <i class="bi bi-geo-alt me-2 text-primary"></i>
                                    <span class="text-truncate">@njesi.Adresa</span>
                                </div>

                                <a asp-controller="Home" asp-action="Create" asp-route-njesiaId="@njesi.NjesiteId"
                                    class="btn btn-outline-primary w-100 rounded-pill fw-bold py-2 transition-all btn-unit-action">
                                    Zgjedh Njesinë <i class="bi bi-chevron-right ms-1"></i>
                                </a>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
}

<style>
    .unit-card {
        border-radius: 20px;
        background: #ffffff;
        cursor: pointer;
    }

        .unit-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(13, 110, 253, 0.1) !important;
            border: 1px solid #0d6efd !important;
        }

    /* Shiriti anësor dekorativ (Blunë e Njësisë) */
    .unit-stripe {
        position: absolute;
        top: 0;
        left: 0;
        width: 6px;
        height: 100%;
        background: #0d6efd; /* Ngjyra primare */
    }

    /* Ikona rrethore e vogël në cep */
    .unit-icon-circle {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-size: 1.2rem;
    }

    .fw-black {
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    /* Butoni i veprimit */
    .btn-unit-action:hover {
        background-color: #0d6efd !important;
        color: white !important;
        box-shadow: 0 4px 15px rgba(13, 110, 253, 0.2);
    }

    .tracking-wider {
        letter-spacing: 1px;
    }
</style>

<style>
    /* Stili për Kartat e Transaksioneve */
    .pending-card {
        border-radius: 20px;
        transition: all 0.3s ease;
        background: #fff;
    }

        .pending-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
            border: 1px solid #ffc107 !important;
        }

    /* Shiriti anësor dekorativ që i bën të duken si njoftime */
    .pending-stripe {
        position: absolute;
        top: 0;
        left: 0;
        width: 6px;
        height: 100%;
        background: #ffc107;
    }

    .checkOut-card {
        border-radius: 20px;
        transition: all 0.3s ease;
        background: #fff;
    }

        .checkOut-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
            border: 1px solid #ff5157 !important;
        }

    .checkOut-stripe {
        position: absolute;
        top: 0;
        left: 0;
        width: 6px;
        height: 100%;
        background: #ff5157;
    }

    .fw-black {
        font-weight: 900;
        color: #2b2b2b;
    }

    .btn-pay:hover {
        background-color: #ffc107 !important;
        border-color: #ffc107 !important;
        color: #ffffff !important;
    }
    .btn-pay1:hover {
        background-color: #ff5157 !important;
        border-color: #ff5157 !important;
        color: #fff !important;
    }

    /* Animacioni i pikës pulsuese */
    .spinner-grow {
        animation-duration: 1.5s;
    }

    /* Opsionale: bëje titullin pak më të ndjeshëm në hover */
    [data-bs-toggle="collapse"]:hover h5 {
        color: #ffc107 !important;
    }
</style>

