@model Parking_web.Models.DTO.NjesiReadDto

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-bottom-5">
                <div class="card-header bg-danger text-white py-3 text-center rounded-top-5">
                    <h5 class="mb-0 fw-bold">Konfirmo Fshirjen e Njësisë</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                        <h4 class="mt-2 text-dark">A jeni i sigurt?</h4>
                        <p class="text-muted">
                            Ky veprim do të fshijë përgjithmonë njësinë <strong>@Model.Emri</strong> dhe të gjitha të dhënat e ndërlidhura.
                        </p>
                    </div>

                    <div class="bg-light p-3 rounded mb-4 text-start">
                        <div class="small text-muted text-uppercase fw-bold mb-2">Detajet e Njësisë:</div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-secondary">ID:</span>
                            <span class="fw-bold">#@Model.NjesiteId</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-secondary">Kodi:</span>
                            <span class="fw-bold text-primary">@Model.Kodi</span>
                        </div>
                        <div class="d-flex justify-content-between py-2">
                            <span class="text-secondary">Adresa:</span>
                            <span class="fw-bold text-dark">@Model.Adresa</span>
                        </div>
                    </div>

                    <form method="post" asp-action="Delete">
                        <input type="hidden" asp-for="NjesiteId" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">
                                Po, Fshije Njësinë
                            </button>
                            <a asp-action="Index2" class="btn btn-link text-secondary text-decoration-none">
                                Anulo, kthehu mbrapa
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}