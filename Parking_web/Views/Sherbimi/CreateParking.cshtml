@model Parking_web.Models.DTO.SherbimParkingDTO

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <span class="fw-semibold h4 pt-1">Shto Shërbim Parkingu</span>
                </div>

                <div class="card-body">
                    <form method="post">

                        <input type="hidden" asp-for="BiznesId" />

                        <div class="mb-3">
                            <label asp-for="EmriCilsimit" class="form-label">Emri i Cilësimit (p.sh. Sezona Verore)</label>
                            <input asp-for="EmriCilsimit" class="form-control" placeholder="Shëno emrin e cilësimit" />
                            <span asp-validation-for="EmriCilsimit" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NjesiteId" class="form-label fw-semibold">Përzgjidh Njësinë</label>

                            @if (ViewBag.IsFixed == true)
                            {
                                <select asp-for="NjesiteId" class="form-select bg-light text-muted"
                                        asp-items="ViewBag.NjesiteList" disabled>
                                </select>

                                <input type="hidden" asp-for="NjesiteId" />
                                <small class="text-info"><i class="bi bi-info-circle me-1"></i> Njësia është paracaktuar.</small>
                            }
                            else
                            {
                                <select asp-for="NjesiteId" class="form-select"
                                        asp-items="ViewBag.NjesiteList">
                                    <option value="">-- Zgjedh Njësinë --</option>
                                </select>
                            }
                            <span asp-validation-for="NjesiteId" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FromHour" class="form-label">Nga Ora</label>
                                <input asp-for="FromHour" type="number" min="0" class="form-control" placeholder="0" default = "0" />
                                <span asp-validation-for="FromHour" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ToHour" class="form-label">Deri te Ora (Opsionale)</label>
                                <input asp-for="ToHour" type="number" class="form-control" placeholder="24" />
                                <span asp-validation-for="ToHour" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Cmimi" class="form-label">Çmimi për Orë (€)</label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input asp-for="Cmimi" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Cmimi" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Anulo</a>
                            <button type="submit" class="btn btn-primary px-4">
                                Ruaj Parkingun
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}