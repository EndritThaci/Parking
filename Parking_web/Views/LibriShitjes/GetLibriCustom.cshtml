@model Parking_web.Models.DTO.LibriShitjesCreateDTO
@using System.Security.Claims
@{
    ViewData["Title"] = "Gjenerimi i Raportit të Shitjes";
}

<div class="container py-5">
    <div class="row justify-content-center ">
        <div class="col-md-8 col-lg-6 ">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-excel py-4 bg-primary text-center text-white">
                    <h3 class="fw-bold mt-2">Libri i Shitjes</h3>
                    <p class="mb-0 opacity-75">Gjenero raportin e shitjeve në Excel</p>
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="GetLibri" method="post" id="reportForm">

                        <div class="mb-4">
                            <label class="form-label fw-bold">Zgjidhni Llojin e Raportit</label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="reportType" id="typeDay" checked>
                                <label class="btn btn-outline-primary" for="typeDay">Ditore</label>

                                <input type="radio" class="btn-check" name="reportType" id="typeMonth">
                                <label class="btn btn-outline-primary" for="typeMonth">Mujor</label>

                                <input type="radio" class="btn-check" name="reportType" id="typeYear">
                                <label class="btn btn-outline-primary" for="typeYear">Vjetor</label>

                                <input type="radio" class="btn-check" name="reportType" id="typeAll">
                                <label class="btn btn-outline-primary" for="typeAll">I Plotë</label>
                            </div>
                        </div>

                        <div id="sectionDay" class="mb-3 d-none">
                            <label class="form-label small fw-bold text-muted">Data specifike</label>
                            <input type="date" name="day" id="specificDateInput" class="form-control border-2" value="@DateTime.Now.ToString("yyyy-MM-dd")" lang="sq-AL" />
                        </div>

                        <div id="sectionMonth" class="mb-3">
                            <label class="form-label small fw-bold text-muted">Muaji</label>
                            <select asp-for="month" class="form-select border-2">
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <option value="@i" selected="@(i == DateTime.Now.Month)">
                                        @System.Globalization.CultureInfo.GetCultureInfo("sq-AL").DateTimeFormat.GetMonthName(i).ToUpper()
                                    </option>
                                }
                            </select>
                        </div>

                        <div id="sectionYear" class="mb-3">
                            <label class="form-label small fw-bold text-muted">Viti</label>
                            <select asp-for="year" class="form-select border-2">
                                @for (int i = DateTime.Now.Year; i >= 2020; i--)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted">Njësia Organizative</label>
                            @if (User.IsInRole("Manager"))
                            {
                                <select class="form-select border-2 bg-light" disabled>
                                    <option>@ViewBag.Njesia?.Emri</option>
                                </select>
                                <input type="hidden" asp-for="njesia" value="@User.FindFirst("NjesiaId")?.Value" />
                            }
                            else
                            {
                                <select asp-for="njesia" class="form-select border-2">
                                    <option value="">Të gjitha Njësitë</option>
                                    @if (ViewBag.Njesia is IEnumerable<dynamic> njesite)
                                    {
                                        foreach (var n in njesite)
                                        {
                                            <option value="@n.NjesiteId">@n.Emri</option>
                                        }
                                    }
                                </select>
                            }
                        </div>

                        <input type="hidden" asp-for="all" id="allHidden" value="false" />

                        <div class="d-grid mt-5">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm py-3 fw-bold">
                                <i class="bi bi-download me-2"></i> Shkarko Raportin (.xlsx)
                            </button>
                            <a asp-controller="Transaksion"
                                   asp-action="@(User.IsInRole("Manager") ? "IndexManager" : "Index")"
                                   asp-route-njesiaId="@Model?.njesia"
                                   class="btn btn-link text-muted text-decoration-none rounded-pill py-3 text-center mt-2">
                                <i class="bi bi-pencil-square me-1"></i> Kthehu
                            </a>
                        </div>
                        
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const typeDay = document.getElementById('typeDay');
        const typeMonth = document.getElementById('typeMonth');
        const typeYear = document.getElementById('typeYear');
        const typeAll = document.getElementById('typeAll');

        const sectionDay = document.getElementById('sectionDay');
        const sectionMonth = document.getElementById('sectionMonth');
        const sectionYear = document.getElementById('sectionYear');
        const allHidden = document.getElementById('allHidden');

        function updateFields() {
            sectionDay.classList.add('d-none');
            sectionMonth.classList.add('d-none');
            sectionYear.classList.add('d-none');

            document.querySelector('[name="day"]').disabled = true;
            document.querySelector('[name="month"]').disabled = true;
            document.querySelector('[name="year"]').disabled = true;

            allHidden.value = "false";

            if (typeDay.checked) {
                sectionDay.classList.remove('d-none');
                document.querySelector('[name="day"]').disabled = false;
            }
            else if (typeMonth.checked) {
                sectionMonth.classList.remove('d-none');
                sectionYear.classList.remove('d-none');
                document.querySelector('[name="month"]').disabled = false;
                document.querySelector('[name="year"]').disabled = false;
                
                if (!document.querySelector('[name="month"]').value) {
                    document.querySelector('[name="month"]').value = new Date().getMonth() + 1;
                }
            } else if (typeYear.checked) {
                sectionYear.classList.remove('d-none');
                document.querySelector('[name="year"]').disabled = false;
            }
            else if (typeAll.checked) {
                allHidden.value = "true";
            }
        }

        [typeDay, typeMonth, typeYear, typeAll].forEach(radio => {
            radio.addEventListener('change', updateFields);
        });

        updateFields();
    </script>
}