@model Parking_web.Models.DTO.NjesiUpdateDto

@{
    ViewData["Title"] = "Përditësimi i Njësisë";
}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card">
                <div class="card-header bg-warning text-white">
                    <span class="fw-semibold h4 pt-1">Përditëso Njësinë</span>
                </div>

                <div class="card-body">
                    <form method="post">

                        <!-- Hidden ID -->
                        <input type="hidden" asp-for="NjesiteId" />

                        <!-- Emri -->
                        <div class="mb-3">
                            <label asp-for="Emri" class="form-label"></label>
                            <input asp-for="Emri" class="form-control" placeholder="Emri i njësisë" />
                            <span asp-validation-for="Emri" class="text-danger small"></span>
                        </div>

                        <!-- Kodi -->
                        <div class="mb-3">
                            <label asp-for="Kodi" class="form-label"></label>
                            <input asp-for="Kodi" class="form-control" placeholder="Kodi i njësisë" />
                            <span asp-validation-for="Kodi" class="text-danger small"></span>
                        </div>

                        <!-- Adresa -->
                        <div class="mb-3">
                            <label asp-for="Adresa" class="form-label"></label>
                            <input asp-for="Adresa" class="form-control" />
                            <span asp-validation-for="Adresa" class="text-danger small"></span>
                        </div>

                        <!-- BiznesId -->
                        <input type="hidden" asp-for="BiznesId" />

                        <!-- Vende te lira -->
                        <div class="mb-3">
                            <label asp-for="VendeTeLira" class="form-label"></label>
                            <input asp-for="VendeTeLira" type="number" class="form-control" />
                            <span asp-validation-for="VendeTeLira" class="text-danger small"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index2" class="btn btn-secondary">Kthehu</a>
                            <button type="submit" class="btn btn-warning">
                                Përditëso Njësinë
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
