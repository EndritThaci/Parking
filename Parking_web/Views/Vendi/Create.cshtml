@model Parking_web.Models.Vendi

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold">Regjistro Vend të Ri</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="VendiEmri" class="form-label fw-semibold">Emri ose Numri i Vendit</label>
                            <input asp-for="VendiEmri" class="form-control" placeholder="Psh: A-101 ose Vendi 01" />
                            <span asp-validation-for="VendiEmri" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="LokacioniId" class="form-label fw-semibold">Përzgjidh Lokacionin</label>

                            <select asp-for="LokacioniId" class="form-select"
                                    asp-items="ViewBag.LokacioniList">
                                <option value="" selected disabled>-- Zgjedh Lokacionin --</option>
                            </select>

                            <span asp-validation-for="LokacioniId" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Anulo</a>
                            <button type="submit" class="btn btn-primary px-4 rounded-pill fw-bold">Ruaj Vendin</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>