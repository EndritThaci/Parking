@model Parking_web.Models.DTO.DetajetReadDto
@{
    ViewData["Title"] = "Fshirja e Detajit";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-bottom-5">
                <div class="card-header bg-danger text-white py-3 text-center rounded-top-5">
                    <h5 class="mb-0 fw-bold">Konfirmo Fshirjen e Tarifës</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-clock-history text-danger" style="font-size: 3rem;"></i>
                        <h4 class="mt-2 text-dark">A jeni i sigurt?</h4>
                        <p class="text-muted">Po fshini rregullin e çmimit për fashën orare <strong>@Model.FromHour:00 - @(Model.ToHour?.ToString() ?? "∞"):00</strong>.</p>
                    </div>

                    <div class="bg-light p-3 rounded mb-4 text-start">
                        <div class="small text-muted text-uppercase fw-bold mb-2">Detajet:</div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span>Çmimi:</span> <span class="fw-bold text-success">@Model.Cmimi.ToString("N2") €</span>
                        </div>
                        <div class="d-flex justify-content-between py-2">
                            <span>ID e Cilësimit:</span> <span class="fw-bold">#@Model.CilsimetiId</span>
                        </div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="DetajetId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">Po, Fshije</button>
                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">Anulo</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>