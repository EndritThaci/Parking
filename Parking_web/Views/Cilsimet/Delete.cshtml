@model Parking_web.Models.DTO.CilsimetReadDto

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-bottom-5">
                <div class="card-header bg-danger text-white py-3 rounded-top-5">
                    <h5 class="mb-0 fw-bold">Konfirmo Fshirjen</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                        <h4 class="mt-2 text-dark">A jeni i sigurt?</h4>
                        <p class="text-muted">Ky veprim do të fshijë cilësimin <strong>@Model.Emri</strong> dhe nuk mund të kthehet mbrapa.</p>
                    </div>

                    <div class="bg-light p-3 rounded mb-4 text-start">
                        <div class="small text-muted text-uppercase fw-bold">Detajet:</div>
                        <div class="d-flex justify-content-between border-bottom py-1">
                            <span>ID:</span> <span class="fw-bold">#@Model.CilsimetiId</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-1">
                            <span>Njësia ID:</span> <span class="fw-bold">@Model.NjesiteId</span>
                        </div>
                        <div class="d-flex justify-content-between py-1">
                            <span>Shërbimi ID:</span> <span class="fw-bold">@Model.SherbimiId</span>
                        </div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="CilsimetiId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold">Po, Fshije</button>
                            <a asp-action="Index" class="btn btn-link text-secondary">Anulo, mbaje këtë cilësim</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>