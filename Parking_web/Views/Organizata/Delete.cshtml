@model Parking_web.Models.Organizata
@{
    ViewData["Title"] = "Fshirja e Organizatës";
}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card">
                <div class="card-header bg-danger text-white">
                    <span class="fw-semibold h4 pt-1">Fshije Organizaten</span>
                </div>

                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="BiznesId" />
                        <!-- Emri Biznesit -->
                        <div class="mb-3">
                            <label asp-for="EmriBiznesit" class="form-label"></label>
                            <input asp-for="EmriBiznesit" disabled class="form-control" placeholder="Business name" />
                        </div>

                        <!-- Numri Unik & Numri Biznesit -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NumriUnikIdentifikues" class="form-label"></label>
                                <input asp-for="NumriUnikIdentifikues" disabled class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="NumriBiznesit" class="form-label"></label>
                                <input asp-for="NumriBiznesit" disabled class="form-control" />
                            </div>
                        </div>

                        <!-- Numri Fiskal & Punetoret -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NumriFiskal" class="form-label"></label>
                                <input asp-for="NumriFiskal" disabled class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="NumriPunetoreve" class="form-label"></label>
                                <input asp-for="NumriPunetoreve" disabled type="number" class="form-control" />
                            </div>
                        </div>

                        <!-- Adresa -->
                        <div class="mb-3">
                            <label asp-for="Adresa" class="form-label"></label>
                            <input asp-for="Adresa" disabled class="form-control" />
                        </div>

                        <!-- Komuna -->
                        <div class="mb-3">
                            <label asp-for="Komuna" class="form-label"></label>
                            <input asp-for="Komuna" disabled class="form-control" />
                        </div>

                        <!-- Telefoni & Email -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Telefoni" class="form-label"></label>
                                <input asp-for="Telefoni" disabled class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" disabled class="form-control" />
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">Kthehu</a>
                            <button type="submit" class="btn btn-danger">
                                Fshije Organizaten
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
