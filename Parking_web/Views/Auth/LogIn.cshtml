@model Parking_web.Models.DTO.LoginDTO

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow mt-5 mb-5">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="bi bi-person-circle text-primary display-1"></i>
                        </div>
                        <h3 class="fw-bold text-primary mb-2">Mirë se vini</h3>
                        <p class="text-muted">Kyquni në llogarin tuaj</p>
                    </div>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <label asp-for="Email" class="form-label">
                                <i class="bi bi-envelope me-2"></i>Email adresa
                            </label>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Password" class="form-control" placeholder="Password" type="password" />
                            <label asp-for="Password" class="form-label">
                                <i class="bi bi-lock me-2"></i>Paswordi
                            </label>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Kyqu
                            </button>
                        </div>

                        <hr class="my-4">
                        <div class="text-center">
                            <small class="text-muted">Ose</small>
                        </div>
                        <hr class="my-4">

                        <div class="text-center">
                            <p class="mb-3 text-muted">Nuk keni një llogari?</p>
                            <a asp-action="Register" class="btn btn-outline-primary">
                                <i class="bi bi-person-plus me-2"></i>Krijo Llogari
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>