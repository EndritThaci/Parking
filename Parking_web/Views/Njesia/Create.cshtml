@model Parking_web.Models.DTO.NjesiOrgDto

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @if (TempData["success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow rounded-pill px-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow rounded-pill px-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card">
                <div class="card-header bg-primary text-white">
                    <span class="fw-semibold h4 pt-1">Krijo Njësi</span>
                </div>

                <div class="card-body">
                    <form method="post">

                        <!-- Emri Njesise -->
                        <div class="mb-3">
                            <label asp-for="Emri" class="form-label"></label>
                            <input asp-for="Emri" class="form-control" placeholder="Emri i njësisë" />
                            <span asp-validation-for="Emri" class="text-danger small"></span>
                        </div>

                        <!-- BiznesId -->
                        @* <div class="mb-3">
                            <label asp-for="BiznesId" class="form-label"></label>
                            <input asp-for="BiznesId" type="number" class="form-control" />
                            <span asp-validation-for="BiznesId" class="text-danger small"></span>
                        </div> *@

                        <!-- Adresa -->
                        <div class="mb-3">
                            <label asp-for="Adresa" class="form-label"></label>
                            <input asp-for="Adresa" class="form-control" />
                            <span asp-validation-for="Adresa" class="text-danger small"></span>
                        </div>

                        <!-- Komuna -->
                        <div class="mb-3">
                            <label asp-for="Kodi" class="form-label"></label>
                            <input asp-for="Kodi" class="form-control" />
                            <span asp-validation-for="Kodi" class="text-danger small"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index2" class="btn btn-secondary">Kthehu</a>
                            <button type="submit" class="btn btn-primary">
                                Krijo Njësinë
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
