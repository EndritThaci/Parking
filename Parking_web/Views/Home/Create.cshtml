@model Parking_web.Models.DTO.TransaksionetCreateDto

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-5">
                <div class="card-header bg-primary text-white py-3 text-center rounded-top-5">
                    <h4 class="mb-0 fw-bold">Konfirmimi i Transaksionit</h4>
                    <small class="opacity-75">Ju lutem rishikoni të dhënat para vazhdimit</small>
                </div>

                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-exclamation-circle text-warning" style="font-size: 3rem;"></i>
                        <h5 class="fw-bold mt-2">A jeni i sigurt?</h5>
                        <p class="text-muted">Po filloni një transaksion të ri me këto të dhëna:</p>
                    </div>

                    <ul class="list-group list-group-flush border rounded mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <span class="text-muted small text-uppercase fw-bold">Vendi i Parkingut:</span>
                            <span class="fw-bold text-dark">@ViewBag.VendiEmri</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <span class="text-muted small text-uppercase fw-bold">Njësisa:</span>
                            <span class="fw-bold text-dark">@ViewBag.NjesiaEmri</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <span class="text-muted small text-uppercase fw-bold">Koha e Fillimit:</span>
                            <span class="fw-bold text-dark">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                        </li>
                    </ul>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="VendiParkimitId" />
                        <input type="hidden" asp-for="NjesiaId" />
                        <input type="hidden" asp-for="CilsimiId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-check2-circle me-2"></i>Konfirmo dhe Vazhdo
                            </button>
                            <a asp-action="Index" class="btn rounded-pill fw-bold border-0">
                                Anulo
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}