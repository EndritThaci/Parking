@model Parking_web.Models.DTO.TransaksionRead

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            @if (TempData["success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow rounded-pill px-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow rounded-pill px-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <div class="card border-0 shadow-lg overflow-hidden mb-4" style="border-radius: 25px;">
                <div class="bg-dark py-4 px-4 text-white">
                    <h3 class="fw-bold mb-0">Detajet dhe Shërbimet</h3>
                    <p class="small opacity-75 mb-0">ID: #@Model.TransaksioniId</p>
                </div>

                <div class="card-body p-4">
                    <div class="row g-3 mb-5 text-center text-md-start">
                        <div class="col-md-4 border-end">
                            <label class="text-muted small fw-bold text-uppercase">Vendi</label>
                            <p class="h5 fw-bold text-dark"><i class="bi bi-p-square me-2 text-primary"></i>@Model.Vendi.VendiEmri, Kati @Model.Vendi.Lokacioni.Kati, @Model.Cilsimi.NjesiOrg.Emri</p>
                        </div>
                        <div class="col-md-4 border-end">
                            <label class="text-muted small fw-bold text-uppercase">Koha e Hyrjes</label>
                            <p class="h6 text-dark">@Model.KohaHyrjes.ToString("HH:mm")</p>
                        </div>
                        <div class="col-md-4">
                            <label class="text-muted small fw-bold text-uppercase">Admin</label>
                            <p class="h6 text-dark">@User.Identity?.Name</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <h6 class="fw-bold mb-3"><i class="bi bi-grid-3x3-gap me-2"></i>Shërbimet e Disponueshme</h6>
                            <div id="availableServices" class="d-flex flex-wrap gap-2">
                                @if (ViewBag.Sherbimet != null)
                                {
                                    foreach (var s in (IEnumerable<dynamic>)ViewBag.Sherbimet)
                                    {
                                        if(s.Cmimi != 0){
                                            <button type="button"
                                                    id="btn-avail-@s.SherbimiId"
                                                    class="btn btn-outline-primary btn-custom-size rounded-pill btn-avail"
                                                    onclick="selectService('@s.SherbimiId', '@s.Emri', '@s.Cmimi')">
                                                @s.Emri <span class="badge bg-primary ms-1">@if(s.Cmimi != 0){@s.Cmimi<span>€</span>}</span>
                                            </button>
                                        }
                                    }
                                }
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-cart-check me-2"></i>Shërbimet e Zgjedhura</h6>
                            <div id="selectedServices" class="d-flex flex-wrap gap-2 p-3 bg-light rounded-4 border border-dashed" style="min-height: 100px;">
                                <p id="emptyMsg" class="text-muted small m-auto">Klikoni shërbimet majtas për t'i shtuar</p>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Edit" method="post" id="mainEditForm" class="mt-4 border-top pt-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="transaksioniId" value="@Model.TransaksioniId" />
                        <div id="hiddenInputsContainer"></div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none fw-bold">Anulo</a>
                            <button type="submit" class="btn btn-dark rounded-pill px-5 py-2 fw-bold shadow">
                                Ruaj Transaksionin <i class="bi bi-check2-circle ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Stilimi i unifikuar për të dy llojet */
    .btn-custom-size {
        padding: 0.375rem 1rem !important; /* Padding fiks */
        font-size: 0.875rem !important; /* Madhësi teksti e barabartë */
        font-weight: 600;
        border-width: 2px !important; /* Trashësi e njëjtë kornize */
        display: inline-flex;
        align-items: center;
        height: 38px; /* Lartësi fikse për të dy */
        transition: all 0.2s ease;
    }

    /* Kur nuk është i zgjedhur (Outline) */
    .btn-avail {
        border-color: #0d6efd !important;
    }

    /* Kur është i zgjedhur (I mbushur Blu) */
    .btn-selected-item {
        background-color: #0d6efd !important;
        border-color: #0d6efd !important;
        color: white !important;
    }

        /* Efekti i kuq kur do ta heqësh */
        .btn-selected-item:hover {
            background-color: #dc3545 !important;
            border-color: #dc3545 !important;
            transform: scale(0.98);
        }
</style>

<script>
    let selectedList = [];

    function selectService(id, emri, cmimi) {
        // Kontrollo nëse është zgjedhur tashmë
        if (selectedList.some(s => s.id === id)) return;

        // Shto në listë
        selectedList.push({ id, emri, cmimi });

        // Fshih butonin nga lista "Disponueshme"
        document.getElementById(`btn-avail-${id}`).classList.add('d-none');

        updateUI();
    }

    function deselectService(id) {
        // Hiqe nga lista
        selectedList = selectedList.filter(s => s.id !== id);

        // Shfaq butonin përsëri te lista "Disponueshme"
        document.getElementById(`btn-avail-${id}`).classList.remove('d-none');

        updateUI();
    }

            function updateUI() {
        const selectedContainer = document.getElementById('selectedServices');
        const hiddenContainer = document.getElementById('hiddenInputsContainer');
        const emptyMsg = document.getElementById('emptyMsg');

        selectedContainer.querySelectorAll('.btn-selected-item').forEach(el => el.remove());
        hiddenContainer.innerHTML = "";

        if (selectedList.length > 0) {
            emptyMsg.classList.add('d-none');
            selectedList.forEach((s, index) => {
                const btn = document.createElement('button');
                btn.type = "button";

                // Përdorim klasat e reja që krijuam në CSS
                btn.className = "btn btn-selected-item btn-custom-size rounded-pill animate__animated animate__fadeIn";

                btn.innerHTML = `${s.emri} <i class="bi bi-x-lg ms-2 small"></i>`;
                btn.onclick = () => deselectService(s.id);
                selectedContainer.appendChild(btn);

                hiddenContainer.innerHTML += `<input type="hidden" name="SherbimiId" value="${s.id}" />`;
            });
        } else {
            emptyMsg.classList.remove('d-none');
        }
    }
</script>